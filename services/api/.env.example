# Content Evaluation local environment

# Backend runtime
CONTENT_EVAL_APP_ENV=development
CONTENT_EVAL_ANALYSIS_PROVIDER_FAMILY=openai
CONTENT_EVAL_OPENAI_API_KEY=
CONTENT_EVAL_OPENAI_MODEL_NAME=gpt-4.1-mini
CONTENT_EVAL_ANTHROPIC_API_KEY=
CONTENT_EVAL_ANTHROPIC_MODEL_NAME=claude-3-5-sonnet-latest
CONTENT_EVAL_GEMINI_API_KEY=
CONTENT_EVAL_GEMINI_MODEL_NAME=gemini-2.0-flash
CONTENT_EVAL_TAVILY_API_KEY=
# Heavier model for fact_check agent (research, compression, final synthesis).
# Leave blank to use the same model as CONTENT_EVAL_*_MODEL_NAME above.
CONTENT_EVAL_DEEP_RESEARCH_MODEL_NAME=
# cheaper model for summarization of research results from Tavily search results
CONTENT_EVAL_DEEP_RESEARCH_SUMMARIZATION_MODEL=gpt-4.1-mini

# Optional tuning
CONTENT_EVAL_ANALYSIS_TEMPERATURE=0
CONTENT_EVAL_ANALYSIS_MAX_RETRIES=3
CONTENT_EVAL_PROVIDER_TIMEOUT_SECONDS=45
CONTENT_EVAL_REQUEST_TIMEOUT_SECONDS=30

# Optional workspace persistence
CONTENT_EVAL_DATABASE_URL=

# Local app URLs
CONTENT_EVAL_API_BASE_URL=http://localhost:8000
CONTENT_EVAL_WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
